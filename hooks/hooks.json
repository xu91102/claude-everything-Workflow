{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node hooks/observe.js pre",
                        "async": true,
                        "timeout": 10
                    }
                ],
                "id": "pre:observe",
                "description": "观察工具调用，记录到 observations.jsonl"
            },
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node scripts/hooks/run-with-flags.js pre:bash:commit-quality scripts/hooks/commit-quality.js standard,strict"
                    }
                ],
                "id": "pre:bash:commit-quality",
                "description": "Pre-commit 质量门: 检查 console.log/debugger/密钥，验证 commit message 格式"
            }
        ],
        "PostToolUse": [
            {
                "matcher": "*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node hooks/observe.js post",
                        "async": true,
                        "timeout": 10
                    }
                ],
                "id": "post:observe",
                "description": "观察工具调用结果"
            },
            {
                "matcher": "Edit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node scripts/hooks/run-with-flags.js post:edit:console-log hooks/check-console-log.js standard,strict"
                    }
                ],
                "id": "post:edit:console-log",
                "description": "检测编辑后文件中的 console.log"
            }
        ],
        "Stop": [
            {
                "matcher": "*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node hooks/evaluate-session.js"
                    }
                ],
                "id": "stop:evaluate-session",
                "description": "会话结束评估，提示提取模式"
            },
            {
                "matcher": "*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node scripts/hooks/session-end.js"
                    }
                ],
                "id": "stop:session-end",
                "description": "会话结束时持久化状态"
            }
        ]
    }
}
